NODE_ENV=development
PORT=8080
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/expense_tracker
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
BCRYPT_SALT_ROUNDS=12
COOKIE_SECURE=false
MAIL_FROM="Expense Tracker <no-reply@example.com>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me
